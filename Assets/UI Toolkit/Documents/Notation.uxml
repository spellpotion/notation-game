<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/UI%20Toolkit/Documents/styles.uss?fileID=7433441132597879392&amp;guid=f282fee335b048548966eb3c5609d99c&amp;type=3#styles"/>
    <ui:VisualElement name="main-container" style="flex-grow: 1; justify-content: center;">
        <ui:VisualElement name="staff-container" style="background-color: rgb(245, 245, 245); aspect-ratio: 8; flex-direction: row; width: 90%; align-self: center;">
            <ui:VisualElement name="vertical-space" style="flex-grow: 1; max-width: 1.8%;"/>
            <ui:VisualElement name="vertical-line" style="flex-grow: 1; max-width: 0.25%; background-color: rgb(26, 26, 26); height: 41.6%; align-self: center;"/>
            <ui:VisualElement name="staff-lines-container" style="flex-grow: 1;">
                <ui:VisualElement name="ledger-line-half" class="horizontal-halfline line-ledger" style="flex-grow: 1;"/>
                <ui:VisualElement name="line-space" class="horizontal-line-space" style="flex-grow: 1;"/>
                <ui:VisualElement name="ledger-line" class="horizontal-line line-ledger" style="flex-grow: 1;"/>
