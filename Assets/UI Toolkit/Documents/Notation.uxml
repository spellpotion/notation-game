                <ui:VisualElement name="line-space" class="horizontal-line-space" style="flex-grow: 1;"/>
                <ui:VisualElement name="staff-line" class="horizontal-line line-staff" style="flex-grow: 1;"/>
                <ui:VisualElement name="line-space" class="horizontal-line-space" style="flex-grow: 1;"/>
                <ui:VisualElement name="ledger-line" class="horizontal-line line-ledger" style="flex-grow: 1;"/>
                <ui:VisualElement name="line-space" class="horizontal-line-space" style="flex-grow: 1;"/>
                <ui:VisualElement name="ledger-line" class="horizontal-line line-ledger" style="flex-grow: 1;"/>
                <ui:VisualElement name="line-space" class="horizontal-line-space" style="flex-grow: 1;"/>
                <ui:VisualElement name="half-line" class="horizontal-halfline line-ledger" style="flex-grow: 1;"/>
            </ui:VisualElement>
            <ui:VisualElement name="note" style="flex-grow: 1; position: absolute; height: 10%; -unity-background-scale-mode: scale-to-fit; aspect-ratio: 1.64; translate: 400% 800%;">
                <ui:Image name="ledger-image" style="background-image: url(&quot;project://database/Assets/Sprites/ledgerline.png?fileID=2800000&amp;guid=5bee6384b3ed86f46b2221a4455ee5fd&amp;type=3#ledgerline&quot;); position: absolute; -unity-background-image-tint-color: rgb(26, 26, 26); flex-grow: 1; translate: -10% 0%; display: none; aspect-ratio: 2; height: 100%;"/>
                <ui:Image name="wholenote-image" style="background-image: url(&quot;project://database/Assets/Sprites/wholenote.png?fileID=2800000&amp;guid=1149410e2e2ce554e96600f480385d0d&amp;type=3#wholenote&quot;); flex-grow: 1; -unity-background-scale-mode: scale-to-fit; -unity-background-image-tint-color: rgb(26, 26, 26); display: flex;"/>
                <ui:Image name="sharp-image" style="position: absolute; -unity-background-scale-mode: scale-to-fit; aspect-ratio: 0.29; height: 280%; background-image: url(&quot;project://database/Assets/Sprites/sharp.png?fileID=2800000&amp;guid=cc2fe4f2ea234b446a6456f4b6902486&amp;type=3#sharp&quot;); -unity-background-image-tint-color: rgb(26, 26, 26); translate: -120% -33%; display: none;"/>
                <ui:Image name="flat-image" style="position: absolute; background-image: url(&quot;project://database/Assets/Sprites/flat.png?fileID=2800000&amp;guid=68fd593a333b2994cbd8206a5f991422&amp;type=3#flat&quot;); -unity-background-scale-mode: scale-to-fit; height: 260%; -unity-background-image-tint-color: rgb(26, 26, 26); aspect-ratio: 0.3; translate: -120% -55%; display: none;"/>
                <ui:VisualElement name="ledger-container" style="flex-grow: 1; position: absolute; height: 300%; width: 120%; translate: -8% -33.3%;">
